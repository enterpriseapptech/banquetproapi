generator eventcenterclient {
  provider = "prisma-client-js"
  output   = "@prisma/catering"
}

datasource banquestproeventsdb {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Catering {
  id                 String        @id @default(uuid()) // Primary key
  name               String?
  eventTypes         String[]
  serviceProviderId  String // owner of this service points to a userid 
  tagLine            String
  depositPercentage  Int @map("depositAmount")  
  discountPercentage Int? @default(0)
  startPrice         Float
  minCapacity        Int?  //minimum count of people the catering service can handle
  maxCapacity        Int?  //maximum count of people the catering service can handle
  description        String?
  dishTypes          String[]
  cuisine            String[]
  images             String[]
  termsOfUse         String
  cancellationPolicy String
  streetAddress      String
  streetAddress2     String
  city               String
  location           String[] // list of locations this catering service should be listed at
  postal             String
  status             ServiceStatus
  isFeatured         Boolean @default(false)
  featureExpiringAt  DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  updatedBy          String?     
  deletedAt          DateTime?
  deletedBy          String?
  rating             Decimal?
  paymentRequired   Boolean? @default(false)
  contact            String?
  // relations
  menu              Menu[]
  subscriptions     ServiceSubscription[]

  @@index([serviceProviderId])
  @@index([status])
  @@index([name])
  @@index([rating])
  @@index([location])
  @@index([cuisine])
  @@index([startPrice])
}

model Menu {
  id               String     @id @default(uuid())
  cateringId       String
  name             String
  description      String?
  images           String[] // array to store the image url
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  updatedBy          String?     
  deletedAt          DateTime?
  deletedBy          String?

  // Relationships
  cateringService   Catering @relation(fields: [cateringId], references: [id])
  @@index([description])
}



model ServiceSubscription {
  id                 String             @id @default(uuid())
  serviceId          String
  subscriptionPlanId String
  invoiceId          String             @unique
  status             SubscriptionStatus @default(PENDING)
  expiryDate         DateTime
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  deletedBy          String?

  catering           Catering           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([status])
  @@index([expiryDate])
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  INACTIVE
  EXPIRED
}
