generator eventcenterclient {
  provider = "prisma-client-js"
  output   = "@prisma/catering"
}

datasource banquestproeventsdb {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Catering {
  id                 String        @id @default(uuid()) // Primary key
  name               String?
  eventTypes         String[]
  serviceProviderId  String // owner of this service points to a userid 
  tagLine            String
  depositPercentage  Int @map("depositAmount")  
  discountPercentage Int? @default(0)
  startPrice         Float
  minCapacity        Int?  //minimum count of people the catering service can handle
  maxCapacity        Int?  //maximum count of people the catering service can handle
  description        String?
  dishTypes          String[]
  cuisine            String[]
  images             String[]
  termsOfUse         String
  cancellationPolicy String
  streetAddress      String
  streetAddress2     String
  city               String
  location           String[] // list of locations this catering service should be listed at
  postal             String
  status             ServiceStatus
  isFeatured         Boolean @default(false)
  featureExpiringAt  DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  updatedBy          String?     
  deletedAt          DateTime?
  deletedBy          String?
  rating             Decimal?
  paymentRequired   Boolean? @default(false)
  contact            String?
  // relations
  menu              Menu[]
  refundPolicy      RefundPolicy?
  subscriptionStatus SubscriptionStatus?
  subscriptionExpiry DateTime?
  subscriptionPlanId String?

  @@index([serviceProviderId])
  @@index([status])
  @@index([name])
  @@index([rating])
  @@index([location])
  @@index([cuisine])
  @@index([startPrice])
}

model Menu {
  id               String     @id @default(uuid())
  cateringId       String
  name             String
  description      String?
  images           String[] // array to store the image url
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  updatedBy          String?     
  deletedAt          DateTime?
  deletedBy          String?

  // Relationships
  cateringService   Catering @relation(fields: [cateringId], references: [id])
  @@index([description])
}





enum ServiceStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  INACTIVE
  EXPIRED
}

/* REFUND POLICY */
model RefundPolicy {
  id               String             @id @default(uuid())
  cateringId       String             @unique
  allowRefunds     Boolean            @default(true)
  refundWindowDays Int                @default(3) // must request refund at least X days before event
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  catering  Catering           @relation(fields: [cateringId], references: [id], onDelete: Cascade)
  tiers     RefundPolicyTier[]
}

model RefundPolicyTier {
  id                  String       @id @default(uuid())
  refundPolicyId      String
  minDaysBeforeEvent  Int
  deductionPercentage Decimal      @banquestproeventsdb.Decimal(5, 2)
  description         String?

  refundPolicy  RefundPolicy  @relation(fields: [refundPolicyId], references: [id], onDelete: Cascade)

  @@index([refundPolicyId])
}
