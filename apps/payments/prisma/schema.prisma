// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "@prisma/payments"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// to do: payments from proseeker to the application for things like kyc, featured, certification e.t.c

/* PAYMENTS */
model Payment {
  id                      String           @id @default(uuid())
  invoiceId               String?
  paymentMethod           PaymentMethod
  userId                  String
  amount                  Decimal          @db.Decimal(10, 2)
  amountCharged           Decimal          @db.Decimal(10, 2)
  reference               String           // reference to track this payment on the payment provider
  paymentReference        String
  paymentAuthorization    Json?
  paidAt                  String
  currency                Currency         @default(NGN)
  paymentReason           PaymentReason
  status                  PaymentStatus
  transactionId           String
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  updatedBy               String?
  deletedAt               DateTime?
  deletedBy               String?

  refund     Refund?
  dispute    Dispute?
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([paymentMethod])
  @@index([userId])
  @@index([reference])
  @@index([paymentReference])
  @@unique([reference, paymentReference, transactionId])
}


/* INVOICES */
model Invoice {
  id                  String        @id @default(uuid())
  reference           String        @unique
  userId              String        // customer who owns this invoice
  serviceProviderId   String?       // SP who receives payment (set for booking/service invoices)
  bookingId           String?
  subscriptionId      String?       // invoice is either for booking or subscription
  serviceType         ServiceType?  // which microservice to notify on payment (for subscriptions)
  serviceId           String?       // the service's ID in the respective DB
  subscriptionPlanId  String?       // which subscription plan was purchased
  items               Json[]
  amountDue           Decimal       @db.Decimal(10, 2) // total amount to be paid
  serviceChargeAmount Decimal?      @db.Decimal(10, 2) // platform service charge portion
  currency            Currency?     @default(NGN)
  note                String?
  billingAddress      Json
  status              InvoiceStatus
  dueDate             DateTime
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?
  deletedBy           String?

  payments      Payment[]
  subscription  Subscriptions? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  walletTransactions WalletTransaction[] @relation("InvoiceToWalletTx")
  
  @@index([userId])
  @@index([serviceProviderId])
  @@index([bookingId])
  @@index([subscriptionId])
  @@index([status])
  @@index([currency])
}


/* REFUNDS */
model Refund {
  id                    String    @id @default(uuid())
  paymentId             String    @unique  // original wallet payment record
  invoiceId             String             // invoice being refunded
  customerId            String             // who requested the refund
  serviceProviderId     String             // who must approve the refund
  bookingId             String?
  refundReason          String             // customer's stated reason
  policySnapshot        Json?              // snapshot of RefundPolicy at time of request
  deductionPercentage   Decimal?  @db.Decimal(5, 2)
  deductionAmount       Decimal?  @db.Decimal(10, 2)
  refundAmount          Decimal   @db.Decimal(10, 2)  // amount customer gets back
  processAt             DateTime?          // set on SP approval: approvedAt + REFUND_PROCESSING_DAYS
  walletTransactionId   String?            // set once wallet movement completes
  status                RefundStatus
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  updatedBy             String?
  deletedAt             DateTime?
  deletedBy             String?

  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  dispute  Dispute?
}

/* DISPUTES */
model Dispute {
  id                String        @id @default(uuid())
  userId            String
  paymentId         String?       @unique  // optional: direct payment dispute
  refundId          String?       @unique  // optional: dispute about a declined refund
  serviceRequestId  String?
  reason            String
  adminNote         String?       // admin resolution note
  status            DisputeStatus
  createdAt         DateTime      @default(now())
  updatedAt         DateTime?
  updatedBy         String?
  deletedAt         DateTime?
  deletedBy         String?

  payment  Payment?  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  refund   Refund?   @relation(fields: [refundId], references: [id])
}

/* WALLET */
model Wallet {
  id         String    @id @default(uuid())
  userId     String?   @unique  // null for PLATFORM wallet
  type       WalletType
  balance    Decimal   @db.Decimal(12, 2) @default(0)
  currency   Currency  @default(NGN)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  transactions  WalletTransaction[]
  withdrawals   Withdrawal[]

  @@index([type])
}

/* WALLET TRANSACTIONS */
model WalletTransaction {
  id            String         @id @default(uuid())
  walletId      String
  type          WalletTxType
  reason        WalletTxReason
  amount        Decimal        @db.Decimal(10, 2)
  balanceBefore Decimal        @db.Decimal(12, 2)
  balanceAfter  Decimal        @db.Decimal(12, 2)
  description   String?
  invoiceId     String?
  paymentId     String?
  refundId      String?
  withdrawalId  String?
  createdAt     DateTime       @default(now())

  wallet  Wallet  @relation(fields: [walletId], references: [id])
  invoice   Invoice? @relation("InvoiceToWalletTx", fields: [invoiceId], references: [id])

  @@index([walletId])
  @@index([reason])
  @@index([invoiceId])
  @@index([paymentId])
}

/* WITHDRAWALS */
model Withdrawal {
  id          String           @id @default(uuid())
  walletId    String
  userId      String
  amount      Decimal          @db.Decimal(10, 2)
  currency    Currency         @default(NGN)
  bankDetails Json
  status      WithdrawalStatus @default(PENDING)
  reference   String           @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  wallet  Wallet  @relation(fields: [walletId], references: [id])

  @@index([userId])
  @@index([status])
}

model Subscriptions {
  id                String            @id @default(uuid())
  serviceProviderId String
  serviceId         String
  type              PaymentType
  subscriptionplanId String
  status            Status
  expiryDate        DateTime
  subscriptionplan  SubscriptionPlans @relation(fields: [subscriptionplanId], references: [id], onDelete: Cascade)
  invoice           Invoice[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime?
  updatedBy  String?
  deletedAt  DateTime?
  deletedBy  String?

  @@index([serviceId])
  @@index([serviceProviderId])
  @@index([status])
  @@index([expiryDate])
}

model Fees {
  id        String   @id @default(uuid())
  name      FeesType @unique
  amount    Decimal
  status    Status
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  @@unique([name, amount])
}

model SubscriptionPlans {
  id          String   @id @default(uuid())
  plan        String
  amount      Decimal
  timeFrame   Int      // number of days this subscription covers
  status      Status
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  deletedAt   DateTime?
  deletedBy   String?

  subscriptions  Subscriptions[]
}

model FeaturedPlans {
  id        String   @id @default(uuid())
  plan      String
  amount    Decimal
  timeFrame Int      // number of days this subscription covers
  status    Status
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?
}

/* ENUMS */
enum Currency {
  NGN
  USD
  GHS
  ZAR
  KES
  XOF
}

enum FeesType {
  KYC
  CERTIFICATION
}

enum PaymentType {
  KYC
  CERTIFICATION
  FEATUREDPLANS
  SUBSCRIPTIONPLANS
}

enum Status {
  ACTIVE
  INACTIVE
}

enum PaymentReason {
  WALLETFUNDING
  SUBSCRIPTION
  KYC
  CERTIFICATION
  FEATURED
  SERVICEREQUEST
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  DISPUTED
  REFUNDED
}

enum InvoiceStatus {
  PENDING
  PARTIALLY_PAID
  OVER_PAID
  PAID
  OVERDUE
}

enum RefundStatus {
  REQUESTED
  APPROVED
  DECLINED
  PROCESSING
  COMPLETED
  FAILED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum ServiceType {
  EVENTCENTER
  CATERING
}

enum PaymentOption {
  CASH
  CARD
  TRANSFER
}

enum PaymentMethod {
  STRIPE
  PAYSTACK
}

enum WalletType {
  USER
  PLATFORM
}

enum WalletTxType {
  CREDIT
  DEBIT
}

enum WalletTxReason {
  TOPUP
  INVOICE_PAYMENT
  SERVICE_CHARGE
  ESCROW_HOLD
  ESCROW_RELEASE
  REFUND
  WITHDRAWAL
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
